# -------------------------------------------------------
# Bowling Bracket Tracker — Environment Variables
# -------------------------------------------------------
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# --- Neon Postgres Database ---
# Get this from your Neon project dashboard at console.neon.tech
# or from Vercel dashboard under Storage > your database > .env.local tab
DATABASE_URL=

# --- Admin Auth ---
# A strong secret used to sign admin session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=your-secret-here

# --- Admin Password ---
# The bcrypt hash of your admin password.
# Generate with: node scripts/hash-password.js yourpassword
ADMIN_PASSWORD_HASH=

# --- App ---
# The base URL of your deployed app (no trailing slash).
# Used for redirects and links.
NEXT_PUBLIC_APP_URL=http://localhost:3000
